# ----- Read questions aloud on the display (optional) -----
# Leave unset to fall back to the display browser's built-in voice.

# RECOMMENDED: ElevenLabs. Set the key; leave GOOGLE_TTS_API_KEY empty.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku   # "Lily" (British female). Any Voice Library ID works.
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ALTERNATIVE: Google Cloud TTS (free tier). If set, takes priority over ElevenLabs.
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=en-GB-Wavenet-F
GOOGLE_TTS_LANG=en-GB
GOOGLE_TTS_RATE=1.0
GOOGLE_TTS_PITCH=1.0
